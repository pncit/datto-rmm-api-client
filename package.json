{
  "name": "datto-rmm-api-client",
  "version": "0.1.14",
  "description": "ESM-only server-side TypeScript client for Datto RMM API v2",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "generate": "node scripts/patch-spec.mjs && orval && node scripts/dedupe-generated-index.mjs && node scripts/widen-response-enums.mjs",
    "generate:raw": "orval",
    "build": "tsup",
    "format": "prettier --write .",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build && npm run test"
  },
  "keywords": [],
  "author": "Rob Gilbreath",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pncit/datto-rmm-api-client.git"
  },
  "bugs": {
    "url": "https://github.com/pncit/datto-rmm-api-client/issues"
  },
  "homepage": "https://github.com/pncit/datto-rmm-api-client#readme",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "axios": "^1.10.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "nock": "^14.0.15",
    "orval": "^7.0.0",
    "prettier": "^3.6.2",
    "tsup": "^8.0.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.16"
  }
}

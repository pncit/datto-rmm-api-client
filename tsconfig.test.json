{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": true,
    "rootDir": ".",
    "types": ["vitest/globals", "node"],
    "allowJs": true,
    "checkJs": true
  },
  "include": [
    "src/**/*.test.ts",
    "src/__tests__/**/*.ts",
    "tests/**/*.ts",
    "scripts/**/*.mjs"
  ],
  "exclude": ["node_modules", "dist"]
}
